{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "sh gradlew bootJar -x test"
  },
  "deploy": {
    "startCommand": "java -jar build/libs/YOUR-JAR-NAME.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}